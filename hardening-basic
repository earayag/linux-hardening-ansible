- name: Basic Linux Hardening
  hosts: all
  become: yes

  tasks:
    - name: Install EPEL on Rocky/RedHat
      dnf:
        name: epel-release
        state: present
      when: ansible_os_family == "RedHat"

    - name: Update apt cache on Debian
      apt:
        update_cache: yes
      when: ansible_os_family == "Debian"

    - name: Update dnf cache on Rocky/RedHat
      dnf:
        update_cache: yes
      when: ansible_os_family == "RedHat"

    - name: Install common packages on Debian
      package:
        name:
          - vim
          - curl
          - wget
          - fail2ban
          - chrony
        state: present
      when: ansible_os_family == "Debian"

    - name: Install common packages on Rocky/RedHat
      package:
        name:
          - vim
          - curl
          - wget
          - fail2ban
          - chrony
        state: present
      when: ansible_os_family == "RedHat"

    - name: Ensure fail2ban service is enabled and running
      service:
        name: fail2ban
        state: started
        enabled: yes

    - name: Ensure chrony service is enabled and running on Debian
      service:
        name: chrony
        state: started
        enabled: yes
      when: ansible_os_family == "Debian"

    - name: Ensure chronyd service is enabled and running on Rocky
      service:
        name: chronyd
        state: started
        enabled: yes
      when: ansible_os_family == "RedHat"

    - name: Create hardening evidence file
      copy:
        dest: /etc/motd
        content: |
          Managed by Ansible
          Basic hardening baseline applied
        owner: root
        group: root
        mode: '0644'
